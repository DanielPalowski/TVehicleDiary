@inject IViewLocalizer Localizer

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vehicle Information Hub</title>

    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/RepairHub/css.css"
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">

    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>

    <style>
      
    </style>
</head>
<body class="min-h-screen" data-currency="@Localizer["currency"]">
    <!-- Header -->
    <header class="header-gradient text-white">
        <div class="container mx-auto px-4">
            <div class="flex items-center justify-between py-4">
                <a asp-controller="Vehicle" asp-action="Index" asp-route-vehicleIDRoute="@Model.vehicleId"
                   class="back-btn text-black bg-white/10 border-white/20 hover:bg-white/20">
                    <i data-lucide="arrow-left" class="w-5 h-5"></i>
                    @Localizer["BackToVehicles"]
                </a>
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-green-400 to-emerald-500 flex items-center justify-center">
                        <i data-lucide="car" class="w-5 h-5 text-white"></i>
                    </div>
                    <div>
                        <h1 class="font-bold">@Localizer["VehicleInformationHub"]</h1>
                        <p class="text-sm text-white/70">@Localizer["CompleteVehicleManagement"]</p>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="container mx-auto px-4 py-6 md:py-8">
        <!-- Hero Section -->
        <div class="hero-section mb-8 md:mb-12">
            <div class="text-center py-8 px-4 md:py-12">
                <h1 class="text-3xl md:text-5xl font-bold mb-4 md:mb-6">
                    <span class="gradient-text">@Localizer["HeroTitle"]</span>
                </h1>
                <p class="text-gray-600 text-lg mb-6 max-w-2xl mx-auto md:text-xl">
                    @Localizer["HeroSubtitle"]
                </p>

                <div class="action-buttons">
                    <a asp-controller="RepairVehicle" asp-action="Index" asp-route-vehicleIDRoute="@Model.vehicleId"
                       class="inline-flex items-center gap-2 bg-gradient-to-r from-green-500 to-emerald-600 text-white px-6 py-3 rounded-xl font-medium hover:opacity-90 transition-opacity shadow-lg">
                        <i data-lucide="history" class="w-5 h-5"></i>
                        @Localizer["ViewCompleteHistory"]
                    </a>
                </div>
            </div>
        </div>

        <!-- Statistics Section with Financial Overview -->
        <div class="mb-8 md:mb-12">
            <h2 class="text-2xl md:text-3xl font-bold mb-2 text-gray-900">@Localizer["FinancialOverview"]</h2>
            <p class="text-gray-600 mb-6 md:mb-8 max-w-2xl">
                @Localizer["FinancialOverviewDescription"]
            </p>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6 mb-8">
                <!-- Repair Stats -->
                <div class="stat-card repair-stat">
                    <div class="flex items-start gap-4">
                        <div class="stat-icon">
                            <i data-lucide="wrench" class="w-6 h-6"></i>
                        </div>
                        <div>
                            <div class="stat-label">
                                @Localizer["TotalRepairCost"]
                            </div>
                            <div class="stat-number" id="repairCost">
                                @Model.TotalRepairCost
                            </div>
                        </div>
                    </div>
                    <p class="stat-description mt-4">
                        @Localizer["TotalRepairCostDescription"]
                    </p>
                </div>

                <!-- Upgrade Stats -->
                <div class="stat-card upgrade-stat">
                    <div class="flex items-start gap-4">
                        <div class="stat-icon">
                            <i data-lucide="zap" class="w-6 h-6"></i>
                        </div>
                        <div>
                            <div class="stat-label">
                                @Localizer["TotalUpgradeCost"]
                            </div>
                            <div class="stat-number" id="upgradeCost">
                                @Model.TotalUpgradeCost
                            </div>
                        </div>
                    </div>
                    <p class="stat-description mt-4">
                        @Localizer["TotalUpgradeCostDescription"]
                    </p>
                </div>

                <!-- Diagnostic Stats -->
                <div class="stat-card diagnostic-stat">
                    <div class="flex items-start gap-4">
                        <div class="stat-icon">
                            <i data-lucide="activity" class="w-6 h-6"></i>
                        </div>
                        <div>
                            <div class="stat-label">

                                @Localizer["TotalDiagnosticCost"]
                            </div>
                            <div class="stat-number" id="diagnosticCost">
                                @Model.TotalDiagnosticCost
                            </div>
                        </div>
                    </div>
                    <p class="stat-description mt-4">
                        @Localizer["TotalDiagnosticCostDescription"]
                    </p>
                </div>
            </div>

            <!-- Total Investment Card -->
            <div class="bg-gradient-to-r from-gray-900 to-slate-900 rounded-2xl p-6 md:p-8 text-white mb-8 md:mb-12">
                <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
                    <div>
                        <h3 class="text-xl md:text-2xl font-bold mb-2">@Localizer["TotalVehicleInvestment"]</h3>
                        <p class="text-gray-300 mb-4 md:mb-0">
                            @Localizer["TotalVehicleInvestmentDescription"]
                        </p>
                    </div>
                    <div class="text-right">
                        <div class="text-3xl md:text-5xl font-bold mb-2" id="totalInvestment">
                            <!-- Total will be calculated by JavaScript -->
                        </div>
                        <p class="text-gray-300">@Localizer["AllTimeMaintenanceCosts"]</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Hub Cards Section -->
        <div class="mb-12">
            <h2 class="text-2xl md:text-3xl font-bold mb-2 text-gray-900">@Localizer["VehicleInformationCategories"]</h2>
            <p class="text-gray-600 mb-8 max-w-2xl">
                @Localizer["VehicleInformationCategoriesDescription"]
            </p>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <!-- Repair Card (GREEN) -->
                <div class="hub-card repair-card">
                    <div class="card-content">
                        <div class="card-icon">
                            <i data-lucide="wrench" class="w-8 h-8"></i>
                        </div>
                        <h3 class="text-xl font-bold mb-3">@Localizer["RepairHistory"]</h3>
                        <p class="text-white/90 mb-6 flex-grow">
                            @Localizer["RepairHistoryDescription"]
                        </p>
                        <div class="mt-auto">
                            <a asp-controller="RepairVehicle" asp-action="Index" asp-route-vehicleIDRoute="@Model.vehicleId"
                               class="btn-outline-light inline-flex items-center justify-center w-full">
                                <span>@Localizer["ViewRepairs"]</span>
                                <i data-lucide="arrow-right" class="w-4 h-4"></i>
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Upgrade Card (BLUE) -->
                <div class="hub-card upgrade-card">
                    <div class="card-content">
                        <div class="card-icon">
                            <i data-lucide="zap" class="w-8 h-8"></i>
                        </div>
                        <h3 class="text-xl font-bold mb-3">@Localizer["UpgradesModifications"]</h3>
                        <p class="text-white/90 mb-6 flex-grow">
                            @Localizer["UpgradesModificationsDescription"]
                        </p>
                        <div class="mt-auto">
                            <a asp-controller="UpgradeVehicle" asp-action="Index" asp-route-vehicleIDRoute="@Model.vehicleId"
                               class="btn-outline-light inline-flex items-center justify-center w-full">
                                <span>@Localizer["ViewUpgrades"]</span>
                                <i data-lucide="arrow-right" class="w-4 h-4"></i>
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Diagnostic Card (ORANGE) -->
                <div class="hub-card diagnostic-card">
                    <div class="card-content">
                        <div class="card-icon">
                            <i data-lucide="activity" class="w-8 h-8"></i>
                        </div>
                        <h3 class="text-xl font-bold mb-3">@Localizer["DiagnosticsHealth"]</h3>
                        <p class="text-white/90 mb-6 flex-grow">
                            @Localizer["DiagnosticsHealthDescription"]
                        </p>
                        <div class="mt-auto">
                            <a asp-controller="DiagnosticVehicle" asp-action="Index" asp-route-vehicleIDRoute="@Model.vehicleId"
                               class="btn-outline-light inline-flex items-center justify-center w-full">
                                <span>@Localizer["ViewDiagnostics"]</span>
                                <i data-lucide="arrow-right" class="w-4 h-4"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="border-t border-gray-200 mt-12">
        <div class="container mx-auto px-4 py-6">
            <div class="flex flex-col md:flex-row items-center justify-between gap-4">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-green-400 to-emerald-500 flex items-center justify-center">
                        <i data-lucide="car" class="w-4 h-4 text-white"></i>
                    </div>
                    <span class="font-medium text-gray-900">@Localizer["VehicleInformationSystem"]</span>
                </div>
                <p class="text-sm text-gray-600">
                    @Localizer["FooterCopyright"]
                </p>
            </div>
        </div>
    </footer>

    <script>
        // Initialize Lucide icons
        lucide.createIcons();

        // Function to parse currency string to number
        function parseCurrency(currencyString) {
            if (!currencyString) return 0;
            // Remove currency symbols, commas, and convert to number
            return parseFloat(currencyString.replace(/[^0-9.-]+/g, ""));
        }

                function formatCurrency(value) {
            const currency = document.body.dataset.currency || "EUR";

            return new Intl.NumberFormat(undefined, {
                style: 'currency',
                currency: currency,
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            }).format(value);
        }

        // Animate stat counters with currency
        document.addEventListener('DOMContentLoaded', function() {
            // Get cost elements
            const repairCostElement = document.getElementById('repairCost');
            const upgradeCostElement = document.getElementById('upgradeCost');
            const diagnosticCostElement = document.getElementById('diagnosticCost');
            const totalInvestmentElement = document.getElementById('totalInvestment');

            // Parse current values
            const repairCost = parseCurrency(repairCostElement.textContent) || 0;
            const upgradeCost = parseCurrency(upgradeCostElement.textContent) || 0;
            const diagnosticCost = parseCurrency(diagnosticCostElement.textContent) || 0;
            const totalCost = repairCost + upgradeCost + diagnosticCost;

            // Function to animate counter
            function animateCounter(element, start, end, duration = 1000) {
                const startTime = performance.now();
                const updateValue = (currentTime) => {
                    const elapsed = currentTime - startTime;
                    const progress = Math.min(elapsed / duration, 1);

                    // Easing function for smooth animation
                    const easeOutQuart = 1 - Math.pow(1 - progress, 4);
                    const currentValue = start + (end - start) * easeOutQuart;

                    element.textContent = formatCurrency(currentValue);

                    if (progress < 1) {
                        requestAnimationFrame(updateValue);
                    } else {
                        element.textContent = formatCurrency(end);
                    }
                };

                requestAnimationFrame(updateValue);
            }

            // Animate all counters
            animateCounter(repairCostElement, 0, repairCost, 1200);
            animateCounter(upgradeCostElement, 0, upgradeCost, 1200);
            animateCounter(diagnosticCostElement, 0, diagnosticCost, 1200);
            animateCounter(totalInvestmentElement, 0, totalCost, 1500);

            // Add hover effects to cards
            const cards = document.querySelectorAll('.hub-card, .stat-card');
            cards.forEach(card => {
                card.addEventListener('mouseenter', () => {
                    card.style.transition = 'all 0.3s ease';
                });
            });

            // Handle mobile menu if exists
            const mobileMenuButton = document.getElementById('mobileMenuButton');
            const mobileMenu = document.getElementById('mobileMenu');

            if (mobileMenuButton && mobileMenu) {
                mobileMenuButton.addEventListener('click', () => {
                    mobileMenu.classList.toggle('hidden');
                });
            }

            // Initialize tooltips for currency values
            const initTooltips = () => {
                const costElements = [repairCostElement, upgradeCostElement, diagnosticCostElement];
                costElements.forEach(element => {
                    element.addEventListener('mouseenter', () => {
                        const value = parseCurrency(element.textContent);
                        if (value > 0) {
                            showTooltip(element, `${formatCurrency(value)} spent`);
                        }
                    });
                });
            };

            // Simple tooltip function
            function showTooltip(element, text) {
                const tooltip = document.createElement('div');
                tooltip.className = 'fixed bg-gray-900 text-white px-3 py-2 rounded-lg text-sm z-50';
                tooltip.textContent = text;
                document.body.appendChild(tooltip);

                const rect = element.getBoundingClientRect();
                tooltip.style.left = `${rect.left + window.scrollX}px`;
                tooltip.style.top = `${rect.top + window.scrollY - 40}px`;

                setTimeout(() => {
                    tooltip.remove();
                }, 2000);
            }

            initTooltips();
        });

        // Handle responsive behavior
        function handleResponsive() {
            const cards = document.querySelectorAll('.hub-card');
            const isMobile = window.innerWidth < 768;

            if (isMobile) {
                cards.forEach(card => {
                    card.style.marginBottom = '1rem';
                });
            } else {
                cards.forEach(card => {
                    card.style.marginBottom = '';
                });
            }
        }

        // Initial call
        handleResponsive();

        // Listen for resize
        window.addEventListener('resize', handleResponsive);
    </script>
</body>
</html>